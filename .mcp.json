{
  "mcpServers": {
    "unstuckarr": {
      "type": "stdio",
      "command": "python",
      "args": ["mcp_unstuckarr_server.py"],
      "env": {
        "UNSTUCKARR_BASE_URL": "http://localhost:7676",
        "UNSTUCKARR_PASSWORD": ""
      }
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": ""
      }
    }
  }
}
