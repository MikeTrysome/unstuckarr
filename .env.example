UNSTUCKARR_SONARR4K_HOST=192.168.1.135
UNSTUCKARR_SONARR4K_PORT=8990
UNSTUCKARR_SONARR4K_API_KEY=jouw_sonarr4k_api_key

UNSTUCKARR_RADARR_HOST=192.168.1.135
UNSTUCKARR_RADARR_PORT=7878
UNSTUCKARR_RADARR_API_KEY=jouw_radarr_api_key

UNSTUCKARR_RADARR4K_HOST=192.168.1.135
UNSTUCKARR_RADARR4K_PORT=7879
UNSTUCKARR_RADARR4K_API_KEY=jouw_radarr4k_api_key

# RDT-client
UNSTUCKARR_RDT_HOST=192.168.1.135
UNSTUCKARR_RDT_PORT=6500
UNSTUCKARR_RDT_USERNAME=jouw_gebruikersnaam
UNSTUCKARR_RDT_PASSWORD=jouw_wachtwoord

# App
UNSTUCKARR_INTERVAL_MINUTES=10
UNSTUCKARR_DATA_DIR=/data

# Auth — stel dit in bij eerste start; daarna wordt de bcrypt hash in de DB opgeslagen
# Je kunt het wachtwoord daarna wijzigen via de Settings pagina
# Minimaal 12 tekens vereist
UNSTUCKARR_PASSWORD=kies_een_sterk_wachtwoord

# Alleen nodig bij lokale ontwikkeling (frontend op :5173, backend op :7676)
# In productie weglaten — frontend en backend draaien op dezelfde origin
# CORS_ORIGINS=http://localhost:5173
