# All connection settings are configured via the Settings UI after first start.
# Environment variables below are optional — use them only if you want to
# pre-seed settings at container startup (e.g. for automated deployments).
# They are seeded into the encrypted DB on first start and not read afterwards.

# ARR instances (optional — configure via Settings UI instead)
# UNSTUCKARR_SONARR_HOST=192.168.1.x
# UNSTUCKARR_SONARR_PORT=8989
# UNSTUCKARR_SONARR_API_KEY=

# UNSTUCKARR_SONARR4K_HOST=192.168.1.x
# UNSTUCKARR_SONARR4K_PORT=8990
# UNSTUCKARR_SONARR4K_API_KEY=

# UNSTUCKARR_RADARR_HOST=192.168.1.x
# UNSTUCKARR_RADARR_PORT=7878
# UNSTUCKARR_RADARR_API_KEY=

# UNSTUCKARR_RADARR4K_HOST=192.168.1.x
# UNSTUCKARR_RADARR4K_PORT=7879
# UNSTUCKARR_RADARR4K_API_KEY=

# RDT-client (optional — configure via Settings UI instead)
# UNSTUCKARR_RDT_HOST=192.168.1.x
# UNSTUCKARR_RDT_PORT=6500
# UNSTUCKARR_RDT_USERNAME=
# UNSTUCKARR_RDT_PASSWORD=

# App
UNSTUCKARR_INTERVAL_MINUTES=10
UNSTUCKARR_DATA_DIR=/data

# Local development only (frontend on :5173, backend on :7676)
# In production, leave this unset — frontend and backend run on the same origin.
# CORS_ORIGINS=http://localhost:5173
